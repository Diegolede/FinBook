{
  "name": "finbook",
  "version": "1.0.8",
  "description": "Aplicación de control de finanzas personales",
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "verify:persistence": "tsc -p tsconfig.main.json && node scripts/verify-persistence.js"
  },
  "keywords": [
    "finanzas",
    "electron",
    "react",
    "typescript"
  ],
  "author": "Diego Ledesma",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^7.0.6"
  },
  "dependencies": {
    "@types/uuid": "^9.0.7",
    "chart.js": "^4.4.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.556.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.finbook.app",
    "productName": "Finbook",
    "copyright": "Copyright © 2026 FinBook - Diego Ledesma",
    "icon": "src/renderer/Finbook-logo.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sqlite3/**/*"
    ],
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "src/renderer/Finbook-logo.png",
      "publisherName": "Finbook",
      "requestedExecutionLevel": "asInvoker",
      "sign": null
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Finance",
      "icon": "src/renderer/Finbook-logo.png"
    }
  }
}
